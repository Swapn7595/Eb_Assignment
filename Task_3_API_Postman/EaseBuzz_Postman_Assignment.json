  "item": [
    {
      "name": "Posts API",
      "item": [
        {
          "name": "Req1_GET",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", () => {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Response time is under 2 seconds\", () => {\r",
                  "    pm.expect(pm.response.responseTime).to.be.below(2000);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Validate response schema\", () => {\r",
                  "    const jsonData = pm.response.json();\r",
                  "    \r",
                  "    pm.expect(jsonData).to.be.an(\"array\");\r",
                  "    pm.expect(jsonData[0]).to.have.all.keys(\"userId\", \"id\", \"title\", \"body\");\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Store first post ID\", () => {\r",
                  "    const jsonData = pm.response.json();\r",
                  "    pm.environment.set(\"post_id\", jsonData[0].id);\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            },
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  ""
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/posts",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "posts"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Req2_POST",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 201\", () => {\r",
                  "    pm.response.to.have.status(201);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Response time < 2s\", () => {\r",
                  "    pm.expect(pm.response.responseTime).to.be.below(2000);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Validate response data matches request\", () => {\r",
                  "    const jsonData = pm.response.json();\r",
                  "    \r",
                  "    pm.expect(jsonData.title).to.eql(pm.environment.get(\"title\"));\r",
                  "    pm.expect(jsonData.body).to.eql(pm.environment.get(\"body\"));\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Store created post ID\", () => {\r",
                  "    const jsonData = pm.response.json();\r",
                  "    pm.environment.set(\"post_id\", jsonData.id);\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            },
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "const randomTitle = \"Title_\" + Math.floor(Math.random() * 1000);\r",
                  "const randomBody = \"Body_\" + Math.floor(Math.random() * 1000);\r",
                  "\r",
                  "pm.environment.set(\"title\", randomTitle);\r",
                  "pm.environment.set(\"body\", randomBody);"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\r\n  \"title\": \"{{title}}\",\r\n  \"body\": \"{{body}}\",\r\n  \"userId\": 1\r\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/posts",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "posts"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Req3_DELETE",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200 or 204\", () => {\r",
                  "    pm.expect([200, 204]).to.include(pm.response.code);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Response time < 2s\", () => {\r",
                  "    pm.expect(pm.response.responseTime).to.be.below(2000);\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "DELETE",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\r\n  \"title\": \"Test Title 2\",\r\n  \"body\": \"Test Body 2\",\r\n  \"userId\": 1\r\n}"
            },
            "url": {
              "raw": "{{base_url}}/posts/{{post_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "posts",
                "{{post_id}}"
              ]
            }
          },
          "response": []
        }
      ]
    }
  ],
